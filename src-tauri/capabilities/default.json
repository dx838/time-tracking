{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main and widget windows",
  "windows": [
    "main",
    "widget"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:window:default",
    "core:app:default",
    "updater:default",
    {
      "identifier": "sql:allow-load",
      "args": {
        "db": "sqlite:timetracker.db"
      }
    },
    {
      "identifier": "sql:allow-select",
      "args": {
        "db": "sqlite:timetracker.db"
      }
    },
    {
      "identifier": "sql:allow-execute",
      "args": {
        "db": "sqlite:timetracker.db"
      }
    }
  ]
}
